# --- Desenvolvimento local ---
# Omita VITE_API_URL: o Vite faz proxy de /api e /ws para a porta 8002
# VITE_API_URL=http://192.168.1.5:8002
# Convites na LAN (IP + porta do Vite; só em dev)
VITE_SHARE_HOST=http://192.168.1.5:5173
DEV_AUTH=true
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.5:5173,http://localhost:5174,http://192.168.1.5:5174
TURN_SECONDS=30
MATCH_TURNS=40
RECONNECT_SECONDS=45
ROOM_STORE_PATH=.data/rooms.json
SUPABASE_URL=
# Dashboard → Settings → API → service_role (secret, nunca no frontend)
SUPABASE_SERVICE_ROLE_KEY=

# --- Produção (Vercel → Settings → Environment Variables) ---
# VITE_API_URL=https://manufut-api.onrender.com
# NÃO defina VITE_SHARE_HOST na Vercel (convites usam https://manufut.vercel.app)
#
# --- Produção (Render / backend manufut-1) ---
# ALLOWED_ORIGINS=https://manufut.onrender.com,https://manufut.vercel.app
# ALLOWED_ORIGIN_REGEX=https://.*\.onrender\.com
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...
