# Omita VITE_API_URL em dev: o Vite faz proxy de /api e /ws para a porta 8002
# VITE_API_URL=http://192.168.1.5:8002
# URL para convites em rede local (IP + porta do Vite; ex.: http://192.168.1.5:5173)
VITE_SHARE_HOST=http://192.168.1.5:5173
DEV_AUTH=true
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.5:5173,http://localhost:5174,http://192.168.1.5:5174
TURN_SECONDS=30
RECONNECT_SECONDS=45
ROOM_STORE_PATH=.data/rooms.json
SUPABASE_URL=
# Dashboard → Settings → API → service_role (secret, nunca no frontend)
SUPABASE_SERVICE_ROLE_KEY=
